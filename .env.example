# NationStates credentials (optional — can also be passed per-call)
NS_PASSWORD=your-nation-password-here
# NS_AUTOLOGIN=your-autologin-token-here

# Default nation (used by some tools as fallback)
NS_NATION=testlandia

# NationStates requires an informative User-Agent with contact information.
NS_USER_AGENT=my-ns-tool/1.0 (contact: you@example.com)
